{
  "name": "nmuriithi-portfolio-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Test suite for Njoki Muriithi portfolio site",
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:a11y": "npx playwright test tests/a11y/",
    "test:visual": "npx playwright test tests/visual/",
    "test:update-snapshots": "npx playwright test tests/visual/ --update-snapshots",
    "serve": "bundle exec jekyll serve"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.40.0"
  }
}
